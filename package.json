{
  "name": "codemap-everywhere",
  "displayName": "CodeMap Everywhere",
  "description": "Fast structured Search Everywhere for large VS Code workspaces and monorepos.",
  "version": "0.3.0",
  "publisher": "codemap",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/liujie2345/CodeMap.git"
  },
  "homepage": "https://github.com/liujie2345/CodeMap#readme",
  "bugs": {
    "url": "https://github.com/liujie2345/CodeMap/issues"
  },
  "keywords": [
    "search",
    "navigation",
    "symbols",
    "codemap",
    "monorepo",
    "large-workspace"
  ],
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:codemap.searchEverywhere",
    "onCommand:codemap.openSearchPanel",
    "onCommand:codemap.buildIndex",
    "onCommand:codemap.syncIndex",
    "onCommand:codemap.showIndexInfo",
    "onCommand:codemap.clearIndex",
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "bin": {
    "codemap": "./out/cli.js"
  },
  "contributes": {
    "commands": [
      {
        "command": "codemap.searchEverywhere",
        "title": "CodeMap: Search Everywhere"
      },
      {
        "command": "codemap.openSearchPanel",
        "title": "CodeMap: Open Search Panel"
      },
      {
        "command": "codemap.buildIndex",
        "title": "CodeMap: Build Index"
      },
      {
        "command": "codemap.syncIndex",
        "title": "CodeMap: Sync Index"
      },
      {
        "command": "codemap.showIndexInfo",
        "title": "CodeMap: Show Index Info"
      },
      {
        "command": "codemap.clearIndex",
        "title": "CodeMap: Clear Index"
      }
    ],
    "keybindings": [
      {
        "command": "codemap.searchEverywhere",
        "key": "ctrl+shift+alt+o",
        "mac": "cmd+shift+alt+o",
        "when": "editorTextFocus || explorerViewletVisible"
      },
      {
        "command": "codemap.openSearchPanel",
        "key": "ctrl+shift+alt+m",
        "mac": "cmd+shift+alt+m",
        "when": "editorTextFocus || explorerViewletVisible"
      }
    ],
    "configuration": {
      "title": "CodeMap Everywhere",
      "properties": {
        "codemap.includeGlobs": {
          "type": "array",
          "default": [
            "**/*.{ts,tsx,js,jsx,mjs,cjs,py,lua,java,kt,kts,go,rs,cs,cpp,cxx,cc,c,h,hpp,php,rb,swift,dart,vue,svelte,sh,bash,zsh,ps1}"
          ],
          "items": {
            "type": "string"
          },
          "description": "Workspace glob patterns included in the CodeMap index."
        },
        "codemap.excludeGlobs": {
          "type": "array",
          "default": [
            "**/node_modules/**",
            "**/.git/**",
            "**/.codemap/**",
            "**/dist/**",
            "**/build/**",
            "**/coverage/**",
            "**/.next/**",
            "**/.turbo/**",
            "**/.cache/**",
            "**/.venv/**",
            "**/venv/**",
            "**/__pycache__/**",
            "**/.pytest_cache/**",
            "**/.mypy_cache/**",
            "**/.ruff_cache/**",
            "**/assets/**",
            "**/resources/**",
            "**/static/**",
            "**/images/**",
            "**/textures/**",
            "**/audio/**",
            "**/video/**",
            "**/logs/**",
            "**/tmp/**",
            "**/temp/**",
            "**/vendor/**",
            "**/generated/**"
          ],
          "items": {
            "type": "string"
          },
          "description": "Workspace glob patterns excluded from the CodeMap index."
        },
        "codemap.maxFileSizeBytes": {
          "type": "number",
          "default": 1048576,
          "minimum": 1024,
          "description": "Maximum file size CodeMap will index."
        },
        "codemap.maxTextMatches": {
          "type": "number",
          "default": 80,
          "minimum": 0,
          "description": "Maximum text matches returned for one search."
        },
        "codemap.autoSyncOnStartup": {
          "type": "boolean",
          "default": true,
          "description": "Automatically sync the CodeMap index shortly after opening a workspace."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "smoke": "npm run compile && node scripts/smoke-search-ranking.js",
    "watch": "tsc -watch -p ./",
    "vsix": "vsce package",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/vscode": "^1.92.0",
    "@vscode/vsce": "^3.2.2",
    "typescript": "^5.8.2"
  }
}
